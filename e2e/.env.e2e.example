# Copy this file to `.env.e2e` (which is gitignored) and fill in real values.
# The QA suite reads these to log in and to know where the app is running.

E2E_BASE_URL=http://127.0.0.1:8000

# Staff / admin login (the /login page)
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=change-me

# Vendor login (the /vendor/login page)
E2E_VENDOR_EMAIL=vendor@example.com
E2E_VENDOR_PASSWORD=change-me

# Database backup, taken automatically before destructive runs (npm run qa:full).
# The path must be writable by the SQL Server service account (its default backup
# folder always is). Leave blank / unset if you don't run destructive tests.
E2E_DB_SERVER=127.0.0.1
E2E_DB_USER=sa
E2E_DB_PASSWORD=change-me
E2E_DB_NAME=your_database
E2E_DB_BACKUP_PATH=C:\path\to\backup\your_database_pre_e2e.bak
