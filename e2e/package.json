{
  "name": "linkportal-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Browser QA automation for Link Portal (Playwright). Self-contained — separate from the app's build.",
  "scripts": {
    "setup": "playwright install chromium",
    "qa": "playwright test --project=setup --project=admin --project=vendor",
    "qa:watch": "cross-env SLOWMO=350 playwright test --project=setup --project=admin --project=vendor --headed",
    "qa:full": "cross-env E2E_DESTRUCTIVE=1 playwright test",
    "qa:full:watch": "cross-env E2E_DESTRUCTIVE=1 SLOWMO=350 playwright test --headed",
    "qa:demo": "cross-env E2E_DESTRUCTIVE=1 SLOWMO=800 playwright test --project=setup --project=workflow --headed",
    "qa:ui": "playwright test --ui",
    "qa:report": "playwright show-report",
    "qa:codegen": "playwright codegen http://127.0.0.1:8000"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5"
  }
}
