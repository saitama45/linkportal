<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <!-- Explicitly handle public assets before the Laravel catch-all -->
                <rule name="Public Assets" stopProcessing="true">
                    <match url="^(build/.*|Files/.*|storage/.*|uploads/.*|favicon\.ico)$" />
                    <action type="Rewrite" url="public/{R:1}" />
                </rule>
                <!-- Redirect root to public folder -->
                <rule name="Root Rewrite" stopProcessing="true">
                    <match url="^$" />
                    <action type="Rewrite" url="public/index.php" />
                </rule>
                <!-- Forward all requests to public folder if file not found in root -->
                <rule name="Imported Rule 1" stopProcessing="true">
                    <match url="^(.*)$" ignoreCase="false" />
                    <conditions logicalGrouping="MatchAll">
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="public/index.php/{R:1}" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
